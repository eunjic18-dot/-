rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "ceunji1218@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidCard(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.attribute in ["공격", "방어", "체력"] &&
             data.color in ["레드", "블루", "골드", "그린", "퍼플", "핑크", "빨강", "파랑", "노랑", "초록", "보라", "분홍"] &&
             data.type in ["단독", "단체", "배포", "상시"] &&
             data.character in ["심성훈", "이서언", "기욱", "진운", "하우주"] &&
             data.category in ["백야", "월광"] &&
             (!('releaseDate' in data) || (data.releaseDate is string && data.releaseDate.size() <= 20));
    }

    function isValidReview(data) {
      return data.cardId is string &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.nickname is string && data.nickname.size() > 0 && data.nickname.size() < 50;
    }

    function isValidComment(data) {
      return data.reviewId is string &&
             data.content is string && data.content.size() < 1000 &&
             data.nickname is string && data.nickname.size() > 0 && data.nickname.size() < 50;
    }

    // Cards: Admin only can create/update/delete. Everyone can read.
    match /cards/{cardId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCard(request.resource.data);
      allow delete: if isAdmin();
    }

    // Reviews: Everyone can read, create, update, delete.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidReview(request.resource.data);
      allow update: if isValidReview(request.resource.data) || 
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']));
      allow delete: if true;
    }

    // Comments: Everyone can read, create, update, delete.
    match /comments/{commentId} {
      allow read: if true;
      allow create, update: if isValidComment(request.resource.data);
      allow delete: if true;
    }

    // Stats: Everyone can increment visits, only admin can read.
    match /stats/{statId} {
      allow read: if isAdmin();
      allow create, update: if true;
    }
  }
}
